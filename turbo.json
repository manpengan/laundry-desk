{
  "$schema": "https://turborepo.dev/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "@laundry/web#test": {
      "dependsOn": ["^build", "@laundry/ui#build"],
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^build", "^typecheck"],
      "outputs": []
    },
    "@laundry/db#test": {
      "dependsOn": ["^build", "@laundry/contracts#build"]
    },
    "@laundry/db#typecheck": {
      "dependsOn": ["^build", "@laundry/contracts#build"]
    },
    "@laundry/db#build": {
      "dependsOn": ["^build", "@laundry/contracts#build"],
      "outputs": ["dist/**"]
    },
    "@laundry/edge-agent#typecheck": {
      "dependsOn": ["^build", "@laundry/contracts#build"]
    },
    "@laundry/edge-agent#test": {
      "dependsOn": ["^build", "@laundry/contracts#build"]
    },
    "@laundry/edge-agent#build": {
      "dependsOn": ["^build", "@laundry/contracts#build"],
      "outputs": ["dist/**"]
    },
    "@laundry/server#typecheck": {
      "dependsOn": ["^build", "@laundry/contracts#build", "@laundry/domain#build"]
    },
    "@laundry/server#test": {
      "dependsOn": ["^build", "@laundry/contracts#build", "@laundry/domain#build"]
    },
    "@laundry/server#build": {
      "dependsOn": ["^build", "@laundry/contracts#build", "@laundry/domain#build"],
      "outputs": ["dist/**"]
    }
  }
}
