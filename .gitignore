# dependencies
node_modules/
.pnpm-store/

# build output
dist/
out/
release/
# 注意：build/ 不在此列——它存放打包源资产（icon.ico / installer.nsh），
# 产物目录是 dist/(electron-builder) 与 out/(electron-vite)。
# 曾误忽略 build/ 导致 CI 打包报 "cannot find build/installer.nsh"。
*.asar
test-results/

# packaged binaries
*.exe
*.dmg
*.pkg
*.zip
*.blockmap

# env / secrets
.env
.env.*
!.env.example

# logs
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
*.tsbuildinfo

# OS
.DS_Store
Thumbs.db
Desktop.ini

# editors
.vscode/*
!.vscode/extensions.json
!.vscode/settings.example.json
.idea/
*.swp
*.swo

# runtime (Electron userData during dev)
userData/
backups/
photos/
*.sqlite
*.sqlite-journal
*.db
*.db-journal
*.db-shm
*.db-wal

# 顺科原始截图（2026-07-19 终审裁决：610MB 且含 GPS/设备 EXIF，不入公开 Git；脱敏代表图另走 docs/assets/shunke/）
/shunke/
