{
  "name": "@laundry/edge-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/main.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch --preserveWatchOutput",
    "lint": "eslint src --ext .ts,.tsx --max-warnings=0",
    "test": "tsc -p tsconfig.json && node --test $(find dist -name '*.test.js')",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "printer-smoke": "tsc -p tsconfig.json && node dist/print/printer-smoke-cli.js"
  },
  "dependencies": {
    "@laundry/contracts": "file:../../packages/contracts",
    "iconv-lite": "0.6.3"
  },
  "devDependencies": {
    "electron": "^41.3.0"
  }
}
