{
  "name": "@laundry/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch --preserveWatchOutput",
    "lint": "eslint src --ext .ts,.tsx --max-warnings=0",
    "test": "tsc -p tsconfig.json && node --test $(find dist -name '*.test.js')",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:e2e:local": "playwright test -c playwright.local.config.ts"
  },
  "dependencies": {
    "@laundry/ui": "file:../../packages/ui",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.7.0",
    "vite": "^6.4.3"
  }
}
