{
  "name": "@laundry/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch --preserveWatchOutput",
    "lint": "eslint src --ext .ts,.tsx --max-warnings=0",
    "test": "tsc -p tsconfig.json && node --test $(find dist -name '*.test.js')",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@laundry/ui": "file:../../packages/ui",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0"
  }
}
